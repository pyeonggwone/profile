# Medical AI test_env runtime configuration

# Fixed test environment versions
WINDOWS_HOST_TARGET="Windows 11"
GUEST_OS_TARGET="Rocky Linux 9.5 x86_64"
PYTHON_VERSION=3.11
K3S_VERSION=v1.30.8+k3s1

# Hyper-V VM settings for Windows 11 host
WINDOWS_VM_NAME=medicalai-rocky9-k3s
WINDOWS_VM_PATH='C:\HyperV\MedicalAI'
ROCKY_ISO_PATH='C:\ISO\Rocky-9.5-x86_64-dvd.iso'
HYPERV_SWITCH_NAME="Default Switch"
HYPERV_EXTERNAL_NET_ADAPTER_NAME=
VM_MEMORY_STARTUP_BYTES=4294967296
VM_PROCESSOR_COUNT=2
VM_VHD_SIZE_BYTES=68719476736

# Kubernetes settings
MEDICALAI_NAMESPACE=medical-ai-test
MEDICALAI_IMAGE_TAG=0.1.0
HOST_VOLUME_ROOT=/opt/medicalai/data
CONTAINER_VOLUME_ROOT=/var/medicalai/data

# Application settings
DATA_SENDER_INTERVAL_SECONDS=10
PII_PROCESSOR_URL=http://pii-processor:8080/process
PII_PROCESSOR_FORWARD_ENABLED=false
PII_PROCESSOR_FORWARD_URL=
UPDATE_POLL_INTERVAL_SECONDS=30
UPDATE_APPLY_ENABLED=false
UPDATE_SOURCE_URL=https://example.invalid/medicalai/releases/current.json

# Azure values required for real Azure integration
# Fill these before enabling Azure upload, ACR pull, Arc, Event Hubs, Storage, or remote update integration.
AZURE_TENANT_ID=__AZURE_TENANT_ID_REQUIRED__
AZURE_SUBSCRIPTION_ID=__AZURE_SUBSCRIPTION_ID_REQUIRED__
AZURE_RESOURCE_GROUP=__AZURE_RESOURCE_GROUP_REQUIRED__
AZURE_LOCATION=koreacentral
AZURE_CLIENT_ID=__AZURE_CLIENT_ID_REQUIRED__
AZURE_CLIENT_SECRET=__AZURE_CLIENT_SECRET_REQUIRED__
ACR_LOGIN_SERVER=__ACR_LOGIN_SERVER_REQUIRED__
AZURE_STORAGE_ACCOUNT=__AZURE_STORAGE_ACCOUNT_REQUIRED__
AZURE_STORAGE_CONTAINER=medicalai-test
AZURE_EVENTHUB_NAMESPACE=__AZURE_EVENTHUB_NAMESPACE_REQUIRED__
AZURE_EVENTHUB_NAME=__AZURE_EVENTHUB_NAME_REQUIRED__