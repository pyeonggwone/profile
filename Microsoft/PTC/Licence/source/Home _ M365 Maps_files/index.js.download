import{hideIfEmbedded,STORE_NAME}from"/js/common.js";document.addEventListener("DOMContentLoaded",()=>{hideIfEmbedded("#footer");const e=localStorage.getItem(STORE_NAME.FLAGS);if(!e)return;const t=JSON.parse(e);t?document.querySelectorAll(".diagram-link").forEach(e=>{const a=e.pathname.slice(e.pathname.lastIndexOf("/")+1,e.pathname.lastIndexOf("."));t.includes(a)&&e.classList.add("bg-flagged")}):console.error("Failed to parse Flags")});