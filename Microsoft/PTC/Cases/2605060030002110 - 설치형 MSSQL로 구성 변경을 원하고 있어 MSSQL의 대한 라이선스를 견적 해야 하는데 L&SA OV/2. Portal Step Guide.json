                            "step_no": 1,
                            "text": "VLSC > Licenses > License Summary 화면에서 고객 Agreement 행을 펼친다.",
                            "fields": {
                                "Agreement Number": "V8923741",
                                "Agreement Type": "Open Value",
                                "Customer Name": "한라테크 주식회사"
                            }
                        },
                        {
