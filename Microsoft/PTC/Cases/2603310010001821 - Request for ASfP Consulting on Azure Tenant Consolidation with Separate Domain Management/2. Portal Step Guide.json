                            "text": "Microsoft Entra admin center > Identity > Groups > All groups",
                            "fields": {}
                        },
                        {
                            "step_no": 2,
                            "text": "New group",
                            "fields": {
                                "Group type": "Security",
                                "Group name": "KEG Manufacturing Users",
                                "Membership type": "Assigned",
                                "Members": "minjun.kim@keg-manufacturing.co.kr"
