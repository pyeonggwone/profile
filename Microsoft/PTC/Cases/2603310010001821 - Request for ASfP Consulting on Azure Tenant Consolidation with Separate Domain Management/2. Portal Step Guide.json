                            "step_no": 1,
                            "text": "Microsoft 365 admin center > Settings > Domains",
                            "fields": {}
                        },
                        {
                            "step_no": 2,
                            "text": "keg-manufacturing.co.kr > DNS records",
                            "fields": {
                                "MX": "keg-manufacturing-co-kr.mail.protection.outlook.com",
