# OpenAI (set EITHER OpenAI OR Azure OpenAI block)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Azure OpenAI (takes precedence if AZURE_OPENAI_API_KEY is set)
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_VERSION=2024-08-01-preview
AZURE_OPENAI_DEPLOYMENT=

# Translation
SOURCE_LANG=en
TARGET_LANG=kr
BATCH_SIZE=8
MAX_TOKENS=4096
TEMPERATURE=0

# Paths
WORK_DIR=work
INPUT_DIR=input
OUTPUT_DIR=output
DONE_DIR=input/done
TM_DB_PATH=work/tm.sqlite
GLOSSARY_PATH=glossary.csv

# PDF engine
# pymupdf: MuPDF/PyMuPDF 기반 파싱/편집 엔진 (기본값, 포맷 유지 개선용)
# pdftr: v3 자체 Rust pdftr CLI 엔진
PDF_ENGINE=pymupdf

# rebuild: 새 PDF를 만들고 원본의 도형/이미지 + 번역 텍스트를 다시 그림 (v4 기본값)
# overlay: 원본 PDF 위에 지우기/번역 텍스트를 덧그림 (v3 방식)
PDF_BUILD_MODE=rebuild

# Python 실행 파일. WSL/Linux 기본값은 python3, Windows 기본값은 python.
PYTHON_BIN=

# pdftr 사용 시 v3 자체 빌드한 pdftr CLI 경로
# PDF_ENGINE=pdftr 이고 비워두면 target/release/pdftr 또는 .exe 자동 탐색
PDF_ENGINE_BIN=

# 한글 등 비-Latin 문자 출력에 사용할 TrueType/OpenType 폰트 (선택)
# 비워두면 kr/ch/jp 출력에서 사용 가능한 기본 후보를 자동 탐색
# 예: /mnt/c/Windows/Fonts/malgun.ttf
PDF_FONT_PATH=

# 굵은 글씨 스타일을 유지할 때 사용할 bold 폰트 (선택)
# 예: /mnt/c/Windows/Fonts/malgunbd.ttf
PDF_FONT_BOLD_PATH=

# CJK 폰트가 영문 원본보다 크게 보이는 현상을 줄이는 배율
PDF_CJK_SIZE_RATIO=0.92

# 원문을 덮을 때 테이블 선/도형 경계선을 침범하지 않기 위한 내부 padding(pt)
PDF_ERASE_PADDING=0.35

# 박스에 맞추기 위해 줄일 수 있는 최소 글자 크기(pt)
PDF_MIN_FONT_SIZE=4.8

# true 면 원본 텍스트를 보존하고 번역 텍스트를 추가 layer 로 덧씌움
PDF_KEEP_ORIGINAL_LANG=false

# true 면 input/ 의 원본을 input/done/ 으로 이동하지 않음
PDF_KEEP_INPUT=false
