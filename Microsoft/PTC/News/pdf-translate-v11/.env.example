# Languages
SOURCE_LANG=en
TARGET_LANG=kr

# Runtime dirs
INPUT_DIR=input
OUTPUT_DIR=output
WORK_DIR=work
GLOSSARY_PATH=glossary.csv
TM_DB_PATH=work/tm.sqlite

# Translation
TRANSLATION_MODE=copy
# copy | openai | azure-openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_CHUNK_SIZE=30
TRANSLATION_PARALLELISM=0
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_VERSION=2024-08-01-preview
AZURE_OPENAI_DEPLOYMENT=

# OCR
OCR_MODE=off
AZURE_VISION_ENDPOINT=
AZURE_VISION_KEY=

# Fonts
FONT_REGULAR=fonts/malgun.ttf
FONT_BOLD=fonts/malgunbd.ttf
FONT_FALLBACK=fonts/NotoSansCJK-Regular.ttc
FONT_SIZE_SCALE=0.88

# Quality
RENDER_SCALE=1.5
RENDER_DIFF_WARN_MEAN=20
RENDER_DIFF_FAIL_MEAN=60
STRICT_TOOLS=false
ALLOW_DEGRADED=true
KEEP_WORK=true
