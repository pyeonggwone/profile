# OpenAI (set EITHER OpenAI OR Azure OpenAI block)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Azure OpenAI (takes precedence if AZURE_OPENAI_API_KEY is set)
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_VERSION=2024-08-01-preview
AZURE_OPENAI_DEPLOYMENT=

# Translation
SOURCE_LANG=en
TARGET_LANG=kr
BATCH_SIZE=8
MAX_TOKENS=4096
TEMPERATURE=0

# Paths
WORK_DIR=work
INPUT_DIR=input
OUTPUT_DIR=output
DONE_DIR=input/done
METADATA_DIR=ebook-metadata
TM_DB_PATH=work/tm.sqlite
GLOSSARY_PATH=glossary.csv
