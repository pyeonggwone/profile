SOURCE_LANG=en
TARGET_LANG=ko

INPUT_DIR=input
OUTPUT_DIR=output
WORK_DIR=work
GLOSSARY_PATH=glossary.csv
STATE_DB_PATH=work/db/state.sqlite
TM_DB_PATH=work/db/tm.sqlite
TERMS_DB_PATH=work/db/terms.sqlite

OPENAI_PROVIDER=openai
OPENAI_CHUNK_SIZE=100
TRANSLATION_PARALLELISM=0
OPENAI_RETRY_MAX=3
OPENAI_RETRY_BASE_MS=1000
OPENAI_TIMEOUT_SECS=300
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_VERSION=2024-08-01-preview
AZURE_OPENAI_DEPLOYMENT=

OCR_MODE=off
OCR_PAGES=1
AZURE_VISION_ENDPOINT=
AZURE_VISION_KEY=

LAYOUT_FIT_ENABLED=true
LAYOUT_FIT_MODE=report-only
LAYOUT_DEFAULT_FONT_SIZE=10
LAYOUT_SAFETY_RATIO=0.90
LAYOUT_WEIGHT_ASCII=0.55
LAYOUT_WEIGHT_HANGUL=1.00
LAYOUT_WEIGHT_CJK=1.00
LAYOUT_WEIGHT_SPACE=0.28
LAYOUT_WEIGHT_REPEATED_SPACE=0.12
LAYOUT_WEIGHT_PUNCT=0.35
LAYOUT_WEIGHT_OTHER=0.80
LAYOUT_SPACING_CREDIT_RATIO=0.25

PDF_TRANSLATION_RENDER_MODE=text-compose
FONT_REGULAR=fonts/malgun.ttf
FONT_BOLD=fonts/malgunbd.ttf
FONT_FALLBACK=fonts/NotoSansCJK-Regular.ttc
ENCODE_UNSUPPORTED_POLICY=preserve-original
REBUILD_MISMATCH_POLICY=preserve-original
STRICT_TOOLS=false
ALLOW_DEGRADED=true
KEEP_WORK=true