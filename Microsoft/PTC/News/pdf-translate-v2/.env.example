# OpenAI (set EITHER OpenAI OR Azure OpenAI block)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Azure OpenAI (takes precedence if AZURE_OPENAI_API_KEY is set)
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_VERSION=2024-08-01-preview
AZURE_OPENAI_DEPLOYMENT=

# Translation
SOURCE_LANG=en
TARGET_LANG=kr
BATCH_SIZE=8
MAX_TOKENS=4096
TEMPERATURE=0

# Paths
WORK_DIR=work
INPUT_DIR=input
OUTPUT_DIR=output
DONE_DIR=input/done
TM_DB_PATH=work/tm.sqlite
GLOSSARY_PATH=glossary.csv

# PDF engine (pdf-translate-v1 의 pdftr CLI 경로)
# 비워두면 pdf-engine/target/release/pdftr (Linux/macOS) 또는 .exe (Windows) 자동 탐색
PDF_ENGINE_BIN=

# 한글 등 비-Latin 문자 출력에 사용할 TrueType 폰트 (선택)
# 예: /usr/share/fonts/truetype/nanum/NanumGothic.ttf
PDF_FONT_PATH=

# true 면 원본 텍스트를 보존하고 번역 텍스트를 추가 layer 로 덧씌움
PDF_KEEP_ORIGINAL_LANG=false

# true 면 input/ 의 원본을 input/done/ 으로 이동하지 않음
PDF_KEEP_INPUT=false
